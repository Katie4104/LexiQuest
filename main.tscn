[node name="Check In Agent" parent="NPCs" instance=ExtResource("8_5vw27")]
position = Vector2(-384, 253)
interaction_mode = "Quiz"
character_name = "Check In Agent"
dialogue_lines = Array[String](["Hello! I can give you the [url=stamp]sello[/url], but my [url=ink]tinta[/url] pad is dry!"])
question = "Could you go to the [url=Gift Shop]Tienda de Regalos[/url] and see if they have a new [url=blue]azul[/url] one?"
choices = Array[String](["I'll be right back with the ink.", "Volveré pronto con la tinta."])
correct_idx = -1
outro_dialogue = Array[String](["Thank you! The [url=Gift Shop]Tienda de Regalos[/url] is in the [url=opposite]opuesto[/url] wing.", "Perfecto! Here is your [url=stamp]sello[/url]."])

[node name="Check In Agent2" parent="NPCs" instance=ExtResource("8_5vw27")]
position = Vector2(-513, 254)
interaction_mode = "Quiz"
character_name = "Check In Agent"
dialogue_lines = Array[String](["Hello! I can give you the [url=stamp]sello[/url], but my [url=ink]tinta[/url] pad is dry!"])
question = "Could you go to the [url=Gift Shop]Tienda de Regalos[/url] and see if they have a new [url=blue]azul[/url] one?"
choices = Array[String](["I'll be right back with the ink.", "Volveré pronto con la tinta."])
