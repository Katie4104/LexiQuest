outro_dialogue = Array[String](["Thank you! The [url=Gift Shop]Tienda de Regalos[/url] is in the [url=opposite]opuesto[/url] wing."])

[node name="Airport Security" parent="NPCs" instance=ExtResource("8_5vw27")]
position = Vector2(-2, 166)
interaction_mode = "Quiz"
character_name = "Airport Security"
dialogue_lines = Array[String](["Wait! You can't bring that [url=water bottle]botella de agua[/url] through security.", "It is a [url=rule]regla[/url] of the airport. You must finish it or throw it away."])
question = "What will you do with the bottle?"
choices = Array[String](["I'll throw it in the trash.", "La tiraré en la basura."])
correct_idx = -1
outro_dialogue = Array[String](["Wait—before you go, your [url=ticket]boleto[/url] also needs a security [url=stamp]sello[/url]. Go to the [url=Information Desk]Información[/url] in the West Wing.", "¡Muy bien! You can now [url=pass]pasar[/url].\""])

[node name="Gift Shop Clerk" parent="NPCs" instance=ExtResource("8_5vw27")]
position = Vector2(295, 313)
interaction_mode = "Quiz"
character_name = "Gift Shop Clerk"
dialogue_lines = Array[String](["Welcome! We have [url=magazines]revistas[/url] and [url=snacks]meriendas[/url]."])
question = "Oh, The [url=Information Desk]Información[/url] sent you for [url=ink]tinta[/url]? I have two colors: [url=Red]Rojo[/url] and [url=Blue]Azul[/url]."
choices = Array[String](["I need the tinta rojo.", "I need the tinta azul."])
correct_idx = 1
outro_dialogue = Array[String](["Hurry back to the [url=check-in]mostrador[/url]!"])

